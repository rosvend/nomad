#all api keys are optional but some features wont work without them :(

#model provider

#ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
# fallback to gemini (free tier)
GEMINI_API_KEY=
# OpenAI — highest priority when set; overrides Gemini and Ollama as the
# primary LLM. Falls back through the chain on errors. Default model is
# gpt-4o-mini (cheap + fast); set OPENAI_MODEL to override (e.g. gpt-4o).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

#web search provider

# searxng
SEARXNG_BASE_URL=http://localhost:8080   
# tavily (requires sign-up, 1000 searches/month free)
TAVILY_API_KEY=
# serpapi (requires sign-up, 250 searches/month free)
SERPAPI_API_KEY=


#place search provider

# Google Maps Platform
GOOGLE_MAPS_API_KEY=


#flight defaults

# Free-form origin used by the Flight agent when the Router doesn't extract
# one from the user's query. Accepts a 3-letter IATA ("LAX") or a known
# city name ("Los Angeles"). Leave blank to require state["origin"] from
# the user / router instead.
DEFAULT_ORIGIN=MDE


# quota tracker (optional)
SERPAPI_MONTHLY_LIMIT=250
# Google Maps Platform — Places Details (with reviews). Each get_reviews
# call uses 2 requests (findplace + details), so 8000 = ~4000 lookups/mo.
GOOGLE_PLACES_MONTHLY_LIMIT=8000
# Maps Grounding via Gemini — shares your Gemini API quota.
GOOGLE_MAPS_GROUNDING_MONTHLY_LIMIT=10000
TAVILY_MONTHLY_LIMIT=1000

#langsmith 
LANGSMITH_API_KEY=